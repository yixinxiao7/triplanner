# Staging environment configuration — TripPlanner backend
# Template for backend/.env.staging (which is gitignored and must not be committed).
#
# Setup:
#   cp backend/.env.staging.example backend/.env.staging
#   # Edit backend/.env.staging with your staging credentials
#   openssl rand -hex 32   # generate a secure JWT_SECRET
#
# The backend automatically loads this file when NODE_ENV=staging
# (set by pm2 via infra/ecosystem.config.cjs). Never modify backend/.env
# for staging — it is reserved for local development only.

# Server
# Staging uses port 3001 to avoid conflict with the local dev server (port 3000).
PORT=3001
NODE_ENV=staging

# Database
# Staging typically uses the same local PostgreSQL instance as dev.
DATABASE_URL=postgres://user:password@localhost:5432/appdb

# Auth
# REQUIRED: Must be a strong random secret (minimum 32 characters).
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-64-char-hex-string-for-staging
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — staging frontend runs on https://localhost:4173 (Vite preview with HTTPS)
CORS_ORIGIN=https://localhost:4173

# HTTPS / TLS — staging uses self-signed certs (generated by infra/scripts/generate-certs.sh)
# Run: ./infra/scripts/generate-certs.sh  to create these before first staging deploy.
SSL_KEY_PATH=../infra/certs/localhost-key.pem
SSL_CERT_PATH=../infra/certs/localhost.pem

# Cookie security — must be true when served over HTTPS
COOKIE_SECURE=true
