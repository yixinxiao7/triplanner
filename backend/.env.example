# Server
# Local development: PORT=3000 (matches vite.config.js dev proxy default)
# Staging: PORT=3001 (changed from 3000 to avoid host conflict — see infra/DEPLOY.md)
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/appdb

# Auth
JWT_SECRET=change-me-to-a-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# Local development: http://localhost:5173 (Vite dev server — npm run dev)
# Staging preview:   https://localhost:4173 (Vite preview server — npm run preview)
CORS_ORIGIN=http://localhost:5173

# HTTPS / TLS (optional — for staging/production)
# Generate certs: ./infra/scripts/generate-certs.sh
# Staging values (PORT must also be set to 3001 when enabling SSL — see DEPLOY.md):
# SSL_KEY_PATH=../infra/certs/localhost-key.pem
# SSL_CERT_PATH=../infra/certs/localhost.pem
# COOKIE_SECURE=true

# Gemini (PDF itinerary import — T-332)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Google Sign-In (OAuth 2.0)
# All optional — Google Sign-In is DISABLED if GOOGLE_CLIENT_ID or
# GOOGLE_CLIENT_SECRET is absent (GET /api/v1/auth/google then redirects to
# /login?error=oauth_unavailable). Create credentials in Google Cloud Console
# (OAuth 2.0 Client, Web application) and set the authorized redirect URI to
# match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Redirect target after the OAuth callback. Falls back to CORS_ORIGIN, then
# http://localhost:5173, if unset. In prod must share an origin with CORS_ORIGIN.
FRONTEND_URL=http://localhost:5173
